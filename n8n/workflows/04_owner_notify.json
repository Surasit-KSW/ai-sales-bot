    },
    "Format: Hot Lead": {
      "main": [[{ "node": "Send LINE Notify", "type": "main", "index": 0 }]]
    }
  },
  "active": false,
  "settings": {
    "executionOrder": "v1",
    "saveManualExecutions": true
  },
