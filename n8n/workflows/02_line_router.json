        "sendBody": true,
        "contentType": "json",
        "body": "={{ JSON.stringify({ source: '02_line_router', severity: 'warning', message: 'AI processing failed or escalated', data: $json }) }}"
      },
      "id": "line-error-09",
      "name": "Report Error",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [1340, 560]
    }
  ],
