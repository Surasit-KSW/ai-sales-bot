        "url": "={{ $env.N8N_WEBHOOK_URL || 'http://localhost:5678' }}/webhook/owner-notify",
        "sendBody": true,
        "contentType": "json",
        "body": "={{ JSON.stringify({ ...$json.lead_data, needs_attention: $json.should_escalate || $json.intent === 'COMPLAINT' }) }}"
      },
      "id": "line-notify-08",
      "name": "Trigger Owner Notify",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
