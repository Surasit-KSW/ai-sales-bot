        "url": "={{ $env.N8N_WEBHOOK_URL || 'http://localhost:5678' }}/webhook/lead-capture",
        "sendBody": true,
        "contentType": "json",
        "body": "={{ JSON.stringify($json.lead_data) }}"
      },
      "id": "line-lead-07",
