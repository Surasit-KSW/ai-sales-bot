# Copy this file to .env and fill in your values
# cp .env.example .env

# -----------------------------------------------------------------------
# Facebook
# -----------------------------------------------------------------------
# Secret token you choose — must match what you enter in Meta Developer Console
FB_VERIFY_TOKEN=your_verify_token_here

# Page Access Token from Meta Developer Console → your app → Messenger/Webhooks
FB_PAGE_ACCESS_TOKEN=your_page_access_token_here

# App Secret from Meta Developer Console → your app → Settings → Basic
FB_APP_SECRET=your_app_secret_here

# -----------------------------------------------------------------------
# LINE
# -----------------------------------------------------------------------
# Channel Secret from LINE Developers Console → your channel → Basic settings
LINE_CHANNEL_SECRET=your_channel_secret_here

# Channel Access Token from LINE Developers Console → your channel → Messaging API
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here

# LINE OA Basic ID (shown as @xxx in LINE app)
LINE_BOT_BASIC_ID=@your_line_id_here

# -----------------------------------------------------------------------
# Auto-reply behaviour
# -----------------------------------------------------------------------
# False = generate reply and queue in dashboard (safe for testing)
# True  = post reply immediately to Facebook / LINE
AUTO_REPLY=False

# -----------------------------------------------------------------------
# Ollama (AI model)
# -----------------------------------------------------------------------
OLLAMA_MODEL=gemma4:e4b
OLLAMA_BASE_URL=http://localhost:11434

# -----------------------------------------------------------------------
# N8N Orchestration
# -----------------------------------------------------------------------
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_WEBHOOK_URL=http://localhost:5678

# -----------------------------------------------------------------------
# LINE Notify (for owner alerts — different from LINE Bot above)
# LINE Notify token: https://notify-bot.line.me/my/
# -----------------------------------------------------------------------
LINE_NOTIFY_TOKEN=your_line_notify_token_here

# -----------------------------------------------------------------------
# Google Sheets (for lead capture — optional)
# -----------------------------------------------------------------------
# Sheet ID from the URL: docs.google.com/spreadsheets/d/{SHEET_ID}/
GOOGLE_SHEET_ID=your_google_sheet_id_here
